# ============================================================
# ストック番長 — 環境変数設定ファイル
# このファイルを .env にコピーして値を入力してください
# cp .env.example .env
# ============================================================

# ── LINE Messaging API ────────────────────────────────────
# LINE Developers (https://developers.line.biz/) から取得

# ① チャンネルID（取得済み）
LINE_CHANNEL_ID=ここにチャンネルIDを貼り付け

# ② チャンネルシークレット（取得済み）
LINE_CHANNEL_SECRET=ここにチャンネルシークレットを貼り付け

# ③ チャンネルアクセストークン（要発行）
#    LINE Developers → チャンネル → Messaging API設定
#    →「チャンネルアクセストークン（長期）」で発行
LINE_CHANNEL_ACCESS_TOKEN=ここにチャンネルアクセストークンを貼り付け

# ④ 送信先 LINE ユーザーID（要確認）
#    取得方法: LINE Developers → チャンネル → Messaging API設定
#             → 「あなたのユーザーID」欄に表示されている
#    または: LINEアプリでボットにメッセージを送信後
#            サーバーのログに "User ID: ..." と表示されます
LINE_USER_ID=ここにあなたのLINEユーザーIDを貼り付け

# ── アプリ設定 ────────────────────────────────────────────
# ローカル開発ポート
PORT=3000

# 公開URL（LINE通知のリンクに使用）
# Vercel デプロイ後は本番URLに変更
APP_URL=http://localhost:3000

# ── Vercel Cron 保護（任意） ──────────────────────────────
# Vercel Cron から /api/notify を呼ぶ際の認証トークン
# 任意の文字列を設定（例: openssl rand -hex 32）
CRON_SECRET=
